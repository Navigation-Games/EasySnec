export enum MistakeType {missing, shuffle}
export enum ResultType {success, fail}

export struct Mistake {
    type: MistakeType,
    checkpoint: int,
}
export struct Grade {
    mistakes: [Mistake],
    result: ResultType,
    course: int,
}


export enum GuiState {
    settings,running
}

